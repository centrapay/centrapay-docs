---
const { image, caption, displayWidth, displayHeight } = Astro.props;
---

<div class="flex flex-col gap-2 text-wrap" style={displayWidth ? `width: ${displayWidth}px; max-width: 100%;` : undefined}>
  <img class="block h-auto my-0" src={image} width={displayWidth} height={displayHeight} style={displayWidth ? `width: ${displayWidth}px; max-width: 100%; height: auto;` : undefined} />
  {caption && <p class="font-normal text-xs text-center">{caption}</p>}
</div>
