---
import { getCollection } from 'astro:content';
import Row from './Row.astro';
import Column from './Column.astro';
import CodePanel from './CodePanel.astro';
import Properties from './Properties.astro';
import ErrorItem from './Error.astro';
import { Code } from 'astro-expressive-code/components';
import createEndpoint from '../utils/createEndpoint';

const { operationId } = Astro.props;

const schemasCollection = await getCollection('openapiSchemas');

const schemasMap = Object.fromEntries(
  schemasCollection.map(entry => [entry.id.split('/').pop(), entry.data])
);

function resolveAll(obj) {
  if (obj && typeof obj === 'object' && '$ref' in obj) {
    const ref = obj['$ref'];
    const [filePart, pointer] = ref.split('#');
    const refId = filePart.split('/').pop().replace('.yaml', '');
    let target = schemasMap[refId] ?? obj;
    if (pointer) {
      for (const part of pointer.replace(/^\//, '').split('/').filter(Boolean)) {
        target = target?.[part] ?? obj;
      }
    }
    return resolveAll(target);
  }
  if (Array.isArray(obj)) return obj.map(resolveAll);
  if (obj && typeof obj === 'object') return Object.fromEntries(Object.entries(obj).map(([k, v]) => [k, resolveAll(v)]));
  return obj;
}

const endpoints = await getCollection('openapiEndpoints');
const entry = endpoints.find(e => e.data.operationId === operationId);

if (!entry) throw new Error(`No operation found for operationId: ${operationId}`);

const operation = resolveAll(entry.data);

const getExample = (mediaType) => Object.values(mediaType?.examples ?? {})[0]?.value;

const endpointData = {
  method: operation.method,
  path: operation.path,
  request: {
    headers: {
      'X-Api-Key': '<TOKEN>',
      ...(operation.requestBody ? { 'Content-Type': 'application/json' } : {}),
    },
    payload: getExample(operation.requestBody?.content?.['application/json']),
  },
  response: getExample(operation.responses?.['200']?.content?.['application/json']),
};

const endpoint = createEndpoint(endpointData);

const customDataTypes = ['timestamp', 'bignumber', 'monetary', 'crn', 'location', 'phonenumber', 'pan'];

const formatDescription = (text) => text
  ?.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
  .replace(/`([^`]+)`/g, '<code>$1</code>') ?? null;

const schema = operation.requestBody?.content?.['application/json']?.schema;
const required = schema?.required ?? [];

const properties = Object.entries(schema?.properties ?? {}).map(([name, prop]) => {
  const type = prop['x-type'] ?? prop.type ?? 'string';
  const formattedType = type.toLowerCase();
  const typeLink = customDataTypes.includes(formattedType) ? `/api/data-types#${formattedType}` : undefined;
  const description = formatDescription(prop.description);
  return {
    name,
    formattedType,
    typeLink,
    description,
    isRequired: required.includes(name),
    isExperimental: !!prop['x-experimental'],
    isDeprecated: !!prop['x-deprecated'],
  };
});

const errors = Object.entries(operation.responses ?? {})
  .filter(([code]) => code !== '200')
  .flatMap(([code, response]) =>
    Object.entries(response?.content?.['application/json']?.examples ?? {})
      .map(([message, example]) => ({
        code,
        message,
        description: formatDescription(example.description),
      }))
  );

const badgeClasses = {
  experimental: 'bg-surface-accent-light text-content-accent border-outline-opaque',
  required: 'bg-surface-accent text-content-on-color border-outline-opaque',
  deprecated: 'text-content-on-color border-outline-opaque bg-red-800',
  default: 'text-content-primary border-outline-opaque bg-surface-tertiary',
};

const badge = (type) => `${badgeClasses[type] ?? badgeClasses.default} type-caption-2 px-2 py-0.5 rounded-full border`;
---

<Row>
  <Column>
    <slot />
    {properties.length > 0 && (
      <Properties>
        {properties.map(({ name, formattedType, typeLink, description, isRequired, isExperimental, isDeprecated }) => (
          <li class="px-0 border-b-0">
            <div class="m-0 flex flex-wrap items-baseline gap-x-3">
              <h4 class="my-0" id={name}>{name}</h4>
              <span class="not-prose inline-flex items-center">
                {typeLink
                  ? <a class={badge('default') + ' underline'} href={typeLink}>{formattedType}</a>
                  : <span class={badge('default')}>{formattedType}</span>
                }
              </span>
              {isRequired && <span class="not-prose inline-flex items-center"><span class={badge('required')}>required</span></span>}
              {isExperimental && <span class="not-prose inline-flex items-center"><span class={badge('experimental')}>experimental</span></span>}
              {isDeprecated && <span class="not-prose inline-flex items-center"><span class={badge('deprecated')}>deprecated</span></span>}
            </div>
            <div data-expandable-slot class="expanded w-full flex-none transition-opacity duration-500 [&>:first-child]:mt-0 [&>:last-child]:mb-0">
              {description && <p set:html={description} />}
            </div>
          </li>
        ))}
      </Properties>
    )}
    {errors.length > 0 && (
      <Properties heading="Errors">
        {errors.map(({ code, message, description }) => (
          <ErrorItem code={code} message={message}>
            {description && <p set:html={description} />}
          </ErrorItem>
        ))}
      </Properties>
    )}
  </Column>
  <Column sticky>
    <CodePanel>
      <Code code={endpoint.requests.curl.code} lang={endpoint.requests.curl.lang} title="Request" frame="terminal" />
    </CodePanel>
    {endpoint.response &&
      <CodePanel>
        <Code code={endpoint.response} lang="json" title="Response" frame="terminal" />
      </CodePanel>
    }
  </Column>
</Row>
